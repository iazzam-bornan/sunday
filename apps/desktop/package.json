{
  "name": "desktop",
  "version": "0.0.3",
  "private": true,
  "main": "src/main.cjs",
  "scripts": {
    "dev": "electron .",
    "build": "cd ../web && bun run build && cd ../desktop && electron-builder --dir",
    "dist": "cd ../web && bun run build && cd ../desktop && electron-builder",
    "release": "cd ../web && bun run build && cd ../desktop && electron-builder --publish always",
    "lint": "echo \"desktop lint: no source lint configured\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "electron-updater": "^6.6.2"
  },
  "devDependencies": {
    "@types/node": "^25.1.0",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "typescript": "^5.9.3"
  },
  "build": {
    "appId": "app.sunday.desktop",
    "productName": "Sunday",
    "directories": {
      "output": "release"
    },
    "files": [
      "assets/**/*",
      "src/**/*",
      "package.json"
    ],
    "icon": "assets/icon",
    "extraResources": [
      {
        "from": "../web/.output",
        "to": "web"
      }
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "iazzam-bornan",
        "repo": "sunday",
        "releaseType": "release"
      }
    ]
  }
}
